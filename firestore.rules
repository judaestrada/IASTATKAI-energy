rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - name: string (required)
    //   - role: string (enum: 'client', 'admin') (required)
    //   - phone: string (optional)
    //   - address: string (optional)
    //   - createdAt: timestamp (required, immutable)
    // 
    // Collection: orders
    // Document ID: random
    // Fields:
    //   - trackingId: string (required)
    //   - userId: string (required)
    //   - items: string [JSON] (required)
    //   - total: number (required)
    //   - status: string (required)
    //   - paymentMethod: string (required)
    //   - date: timestamp (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "juandavidestradagomez@gmail.com" && request.auth.token.email_verified == true));
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // Domain Validators
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'name', 'role', 'phone', 'address', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['client', 'admin'] &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 20)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 200)) &&
             data.createdAt is string; // using ISO string for simplicity here
    }

    function isValidOrder(data) {
      return hasOnlyAllowedFields(['trackingId', 'userId', 'items', 'total', 'status', 'paymentMethod', 'date']) &&
             data.trackingId is string && data.trackingId.size() > 0 && data.trackingId.size() < 50 &&
             data.userId is string && data.userId.size() > 0 &&
             data.items is string && data.items.size() < 20000 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending_payment', 'processing', 'shipped', 'delivered', 'failed'] &&
             data.paymentMethod is string && data.paymentMethod.size() < 50 &&
             data.date is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && 
                    isOwner(userId) && 
                    isValidUser(request.resource.data) && 
                    request.resource.data.uid == userId &&
                    ((request.resource.data.role == 'client') || isAdmin());
                    
      allow update: if isAuthenticated() && 
                    isOwner(userId) && 
                    isValidUser(request.resource.data) && 
                    uidNotModified() && 
                    areImmutableFieldsUnchanged(['createdAt', 'email']) &&
                    ((request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid &&
                    isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data) && areImmutableFieldsUnchanged(['userId', 'items', 'total', 'date', 'trackingId']);
    }
  }
}
